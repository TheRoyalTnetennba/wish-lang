# ─────────────────────────────────────────────────────────────────────────────
# Wish Language — Environment Configuration
# Copy this file to .env and fill in the values you need.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Which backend to use as the compiler.
#
# Cloud providers:
#   openai          — OpenAI API          (requires OPENAI_API_KEY)
#   anthropic       — Anthropic API       (requires ANTHROPIC_API_KEY)
#
# Local providers (no API key needed):
#   lmstudio        — LM Studio           (default base URL: http://localhost:1234/v1)
#   ollama          — Ollama              (default base URL: http://localhost:11434/v1)
#   openai-compat   — Any OpenAI-compatible server (requires WISH_BASE_URL)
#
# If not set, Wish will auto-detect based on whichever cloud API key is present.
#
# WISH_PROVIDER=anthropic

# ── Model Override ────────────────────────────────────────────────────────────
# Override the default model for the selected provider.
#
# Defaults:
#   openai        → gpt-4o
#   anthropic     → claude-sonnet-4-6
#   lmstudio      → local-model
#   ollama        → llama3
#   openai-compat → local-model
#
# For lmstudio and ollama, set this to the exact model name loaded in the server.
#
# WISH_MODEL=gpt-4o
# WISH_MODEL=claude-sonnet-4-6
# WISH_MODEL=llama3.1:8b

# ── Output Directory ──────────────────────────────────────────────────────────
# Where the compiled Node.js project is written, relative to the wish project root.
# Default: out
#
# WISH_OUTPUT_DIR=out

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required when WISH_PROVIDER=openai.
#
# OPENAI_API_KEY=sk-...

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required when WISH_PROVIDER=anthropic.
#
# ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI-compatible endpoint ────────────────────────────────────────────────
# Required when WISH_PROVIDER=openai-compat.
# Also accepted for lmstudio and ollama if you want to override the default port.
#
# WISH_BASE_URL=http://localhost:1234/v1

# ── API key for local / custom servers ───────────────────────────────────────
# Most local servers don't validate this, but some self-hosted deployments do.
# Defaults to "local" when not set.
#
# WISH_API_KEY=local
